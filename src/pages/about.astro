---

import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPost = await getEntry("spec", "about");
const aboutPostZh = await getEntry("spec", "about-zh");

if (!aboutPost || !aboutPostZh) {
	throw new Error("About page content not found");
}

const { Content: ContentEn } = await render(aboutPost);
const { Content: ContentZh } = await render(aboutPostZh);
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <div class="about-lang-tabs mb-6 flex justify-end gap-2" aria-label="About language switcher">
                <button class="about-lang-tab active" type="button" data-about-lang-button="en" aria-pressed="true">EN</button>
                <button class="about-lang-tab" type="button" data-about-lang-button="zh" aria-pressed="false">中文</button>
            </div>
            <div data-about-lang-panel="en">
                <Markdown class="mt-2">
                    <ContentEn />
                </Markdown>
            </div>
            <div data-about-lang-panel="zh" hidden>
                <Markdown class="mt-2">
                    <ContentZh />
                </Markdown>
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
    .about-lang-tab {
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.35rem 0.85rem;
        color: var(--text-50);
        background: var(--btn-plain-bg);
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 1.25rem;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
    }

    .about-lang-tab:hover,
    .about-lang-tab.active {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--btn-plain-bg-hover);
    }

    :global(.news-list),
    :global(.publication-list) {
        display: grid;
        gap: 1.1rem;
        margin-top: 1rem;
    }

    :global(.news-card),
    :global(.publication-card) {
        overflow: hidden;
        border: 1px solid var(--line-divider);
        border-left: 4px solid var(--primary);
        border-radius: var(--radius-large);
        background: color-mix(in oklab, var(--card-bg) 92%, transparent);
        box-shadow: 0 12px 32px rgb(0 0 0 / 4%);
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease,
            transform 0.2s ease,
            background-color 0.2s ease;
    }

    :global(.publication-card) {
        cursor: pointer;
    }

    :global(.news-card) {
        padding: 1rem 1.1rem;
    }

    :global(.publication-card:hover),
    :global(.publication-card[open]),
    :global(.news-card:hover) {
        border-color: color-mix(in oklab, var(--primary) 45%, var(--line-divider));
        box-shadow: 0 16px 38px rgb(0 0 0 / 7%);
        transform: translateY(-1px);
    }

    :global(.publication-summary) {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.75rem;
        padding: 1rem 1.1rem;
        list-style: none;
        user-select: none;
    }

    :global(.publication-summary::-webkit-details-marker) {
        display: none;
    }

    :global(.publication-cue) {
        align-self: start;
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.2rem 0.65rem;
        color: var(--primary);
        background: var(--btn-plain-bg);
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1.3;
        white-space: nowrap;
    }

    :global(.publication-card[open] .publication-cue) {
        border-color: var(--primary);
        background: var(--btn-plain-bg-hover);
    }

    :global(.news-title),
    :global(.publication-title) {
        margin: 0;
        color: var(--text-90);
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.45;
    }

    :global(.news-meta) {
        margin: 0.25rem 0 0;
        color: var(--text-50);
        font-size: 0.9rem;
        font-weight: 600;
    }

    :global(.news-description) {
        margin: 0.45rem 0 0;
        color: var(--text-75);
        line-height: 1.7;
    }

    :global(.publication-title) {
        margin: 0;
    }

    :global(.publication-authors) {
        margin: 0.35rem 0 0;
        color: var(--text-75);
        line-height: 1.7;
    }

    :global(.publication-venue) {
        margin: 0.25rem 0 0;
        color: var(--text-50);
        font-style: italic;
    }

    :global(.publication-body) {
        border-top: 1px solid var(--line-divider);
        padding: 0.9rem 1.1rem 1.05rem;
        color: var(--text-75);
        cursor: default;
    }

    :global(.publication-body h4) {
        margin: 0.9rem 0 0.25rem;
        color: var(--text-90);
        font-size: 0.95rem;
        font-weight: 700;
    }

    :global(.publication-links) {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0;
    }

    :global(.publication-links a),
    :global(.publication-resource),
    :global(.publication-link-disabled) {
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.25rem 0.75rem;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none !important;
    }

    :global(.publication-resource) {
        color: var(--primary);
        background: var(--btn-plain-bg);
    }

    :global(.publication-link-disabled) {
        color: var(--text-30);
        cursor: not-allowed;
    }

    @media (max-width: 640px) {
        :global(.publication-summary) {
            grid-template-columns: 1fr;
        }

        :global(.publication-cue) {
            justify-self: start;
        }
    }

    :global(.publication-bibtex) {
        position: relative;
        overflow-x: auto;
        border: 1px solid color-mix(in oklab, var(--primary) 18%, var(--line-divider));
        border-radius: var(--radius-large);
        margin-top: 0.65rem;
        padding: 2.55rem 1rem 1rem;
        background:
            linear-gradient(
                180deg,
                color-mix(in oklab, var(--primary) 8%, transparent),
                transparent 3.2rem
            ),
            var(--codeblock-bg);
        color: var(--text-75);
        box-shadow: inset 0 1px 0 rgb(255 255 255 / 5%);
        font-family:
            "JetBrains Mono Variable",
            ui-monospace,
            SFMono-Regular,
            Menlo,
            Monaco,
            Consolas,
            "Liberation Mono",
            "Courier New",
            monospace;
        font-size: 0.82rem;
        line-height: 1.7;
        white-space: pre;
        scrollbar-width: thin;
    }

    :global(.publication-bibtex::before) {
        content: "BibTeX";
        position: absolute;
        top: 0.75rem;
        left: 1rem;
        border-radius: 999px;
        border: 1px solid color-mix(in oklab, var(--primary) 28%, var(--line-divider));
        padding: 0.15rem 0.6rem;
        color: var(--primary);
        background: var(--card-bg);
        font-family: inherit;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0;
    }

    :global(.publication-bibtex code) {
        display: block;
        padding: 0;
        background: transparent;
        color: inherit;
        overflow: visible;
    }

    :global(.publication-bibtex code::before),
    :global(.publication-bibtex code::after) {
        content: none;
    }
</style>

<script>
    const storageKey = "about-lang";
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-about-lang-button]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-about-lang-panel]"));

    const setAboutLang = (lang: string) => {
        buttons.forEach((button) => {
            const isActive = button.dataset.aboutLangButton === lang;
            button.classList.toggle("active", isActive);
            button.setAttribute("aria-pressed", String(isActive));
        });

        panels.forEach((panel) => {
            panel.hidden = panel.dataset.aboutLangPanel !== lang;
        });

        localStorage.setItem(storageKey, lang);
    };

    const initialLang = localStorage.getItem(storageKey) ?? (navigator.language.startsWith("zh") ? "zh" : "en");
    setAboutLang(initialLang);

    buttons.forEach((button) => {
        button.addEventListener("click", () => {
            setAboutLang(button.dataset.aboutLangButton ?? "en");
        });
    });
</script>
