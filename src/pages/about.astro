---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPost = await getEntry("spec", "about");
const aboutPostZh = await getEntry("spec", "about-zh");

if (!aboutPost || !aboutPostZh) {
	throw new Error("About page content not found");
}

const { Content: ContentEn } = await render(aboutPost);
const { Content: ContentZh } = await render(aboutPostZh);

// 编译期导入 src/content/spec/awards/ 下所有证书图片
const certImageRecords = import.meta.glob(
	"../content/spec/awards/*.{png,jpg,jpeg,webp,gif}",
	{ eager: true, query: "?url", import: "default" },
) as Record<string, string>;

const certImageMap: Record<string, string> = {};
for (const [path, url] of Object.entries(certImageRecords)) {
	const filename = path.split("/").pop();
	if (filename) certImageMap[filename] = url;
}
---

<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="about-shell">
        <main class="about-shell-main">
            <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
                <div class="card-base z-10 px-9 py-6 relative w-full ">

                    <div class="about-lang-tabs flex justify-end gap-2" aria-label="About language switcher">
                        <button class="about-lang-tab active" type="button" data-about-lang-button="en" aria-pressed="true">EN</button>
                        <button class="about-lang-tab" type="button" data-about-lang-button="zh" aria-pressed="false">中文</button>
                    </div>

                    <div data-about-lang-panel="en" class="about-content">
                        <Markdown class="mt-2">
                            <ContentEn />
                        </Markdown>
                    </div>
                    <div data-about-lang-panel="zh" class="about-content" hidden>
                        <Markdown class="mt-2">
                            <ContentZh />
                        </Markdown>
                    </div>
                </div>
            </div>
        </main>

        <aside class="about-toc" data-about-toc aria-label="On this page" hidden>
            <p class="about-toc-title" data-about-toc-title>On this page</p>
            <ol class="about-toc-list" data-about-toc-list></ol>
        </aside>
    </div>

    <!-- 证书弹窗 -->
    <div class="cert-modal" data-cert-modal hidden role="dialog" aria-modal="true" aria-labelledby="cert-modal-caption">
        <div class="cert-modal-backdrop" data-cert-modal-backdrop aria-hidden="true"></div>
        <div class="cert-modal-stage" data-cert-modal-stage>
            <button class="cert-modal-close" data-cert-modal-close type="button" aria-label="Close">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 6 L18 18 M18 6 L6 18"></path>
                </svg>
            </button>
            <div class="cert-modal-image-wrap">
                <div class="cert-modal-spinner" data-cert-modal-spinner aria-hidden="true"></div>
                <img class="cert-modal-image" data-cert-modal-img src="" alt="" />
            </div>
            <p class="cert-modal-caption" id="cert-modal-caption" data-cert-modal-title></p>
        </div>
    </div>
</MainGridLayout>

<script is:inline define:vars={{ certImageMap }}>
    window.__certImageMap = certImageMap;
</script>

<style>
    /* ============ 整体布局：宽屏时目录悬浮于右侧 ============ */
    .about-shell {
        position: relative;
        display: block;
    }
    .about-shell-main { min-width: 0; }

    /* 目录改为固定定位，由 JS 控制 left / top */
    .about-toc {
        position: fixed;
        z-index: 50;
        top: 5rem;               /* 与顶部导航间距，JS 会动态覆盖 */
        width: 14.5rem;
        max-height: calc(100vh - 7rem);
        overflow-y: auto;
        padding: 0.95rem 1rem;
        border: 1px solid var(--line-divider);
        border-radius: var(--radius-large);
        background: color-mix(in oklab, var(--card-bg) 88%, transparent);
        -webkit-backdrop-filter: blur(10px) saturate(140%);
        backdrop-filter: blur(10px) saturate(140%);
        box-shadow: 0 10px 28px -18px rgb(0 0 0 / 35%);
        scrollbar-width: thin;
        scrollbar-color: color-mix(in oklab, var(--primary) 25%, transparent) transparent;
        transition: opacity 0.2s;
    }
    .about-toc[hidden] {
        display: none;
    }
    .about-toc::-webkit-scrollbar { width: 4px; }
    .about-toc::-webkit-scrollbar-thumb {
        background: color-mix(in oklab, var(--primary) 30%, transparent);
        border-radius: 999px;
    }

    .about-toc-title {
        margin: 0 0 0.55rem;
        padding: 0 0.55rem;
        color: var(--text-50);
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
    }

    .about-toc-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.12rem;
    }
    .about-toc-list li {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .about-toc-link {
        display: block;
        padding: 0.4rem 0.55rem;
        border-left: 2px solid transparent;
        border-radius: 6px;
        color: var(--text-75);
        font-size: 0.85rem;
        font-weight: 500;
        line-height: 1.4;
        text-decoration: none;
        transition: color 0.18s, background-color 0.18s, border-color 0.18s, padding-left 0.18s;
    }
    .about-toc-link:hover {
        color: var(--text-90);
        background: var(--btn-plain-bg);
        padding-left: 0.7rem;
    }
    .about-toc-link.is-active {
        color: var(--primary);
        background: color-mix(in oklab, var(--primary) 7%, var(--btn-plain-bg));
        border-left-color: var(--primary);
        font-weight: 600;
        padding-left: 0.7rem;
    }

    /* ============ 语言切换 ============ */
    .about-lang-tabs {
        margin-bottom: 1rem;
    }
    .about-lang-tab {
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.35rem 0.85rem;
        color: var(--text-50);
        background: var(--btn-plain-bg);
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 1.25rem;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
    }
    .about-lang-tab:hover,
    .about-lang-tab.active {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--btn-plain-bg-hover);
    }

    /* ============ 章节标题 ============ */
    :global(.about-content h1),
    :global(.about-content h2) {
        position: relative;
        display: block !important;
        margin: 2.4rem 0 1.2rem !important;
        padding: 0 0 0.7rem !important;
        font-size: 1.4rem !important;
        font-weight: 800 !important;
        color: var(--text-90) !important;
        border-bottom: 1px solid var(--line-divider) !important;
        letter-spacing: -0.005em;
        scroll-margin-top: 5rem;
    }
    :global(.about-content h1::before),
    :global(.about-content h2::before) {
        content: none !important;
    }
    :global(.about-content h1::after),
    :global(.about-content h2::after) {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 2.4rem;
        height: 2px;
        background: var(--primary);
        border-radius: 999px;
    }
    :global(.about-content > :first-child h2),
    :global(.about-content > h2:first-child),
    :global(.about-content > :first-child h1),
    :global(.about-content > h1:first-child) {
        margin-top: 0.5rem !important;
    }
    :global(.about-content hr) {
        display: none !important;
    }

    /* ============ 教育经历 时间线 ============ */
    :global(.edu-list) { display: grid; gap: 0.85rem; margin-top: 0.25rem; }
    :global(.edu-card) {
        display: grid;
        grid-template-columns: 1.5rem 1fr;
        gap: 0.85rem;
        padding: 1.05rem 1.15rem;
        border: 1px solid var(--line-divider);
        border-radius: var(--radius-large);
        background: color-mix(in oklab, var(--card-bg) 92%, transparent);
        transition: border-color 0.22s, transform 0.22s, box-shadow 0.22s, background-color 0.22s;
    }
    :global(.edu-card:hover) {
        border-color: color-mix(in oklab, var(--primary) 35%, var(--line-divider));
        box-shadow: 0 14px 30px rgb(0 0 0 / 5%);
        transform: translateY(-1px);
    }
    :global(.edu-marker) { position: relative; width: 1.5rem; }
    :global(.edu-marker::before) {
        content: "";
        position: absolute;
        top: 0.45rem;
        left: 50%;
        transform: translateX(-50%);
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--primary);
        box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 16%, transparent), 0 0 0 1px var(--card-bg);
    }
    :global(.edu-marker::after) {
        content: "";
        position: absolute;
        top: 1.5rem;
        bottom: -1rem;
        left: 50%;
        transform: translateX(-50%);
        width: 2px;
        background: linear-gradient(to bottom, color-mix(in oklab, var(--primary) 30%, var(--line-divider)), color-mix(in oklab, var(--primary) 8%, var(--line-divider)));
        border-radius: 999px;
    }
    :global(.edu-list .edu-card:last-child .edu-marker::after) { display: none; }
    :global(.edu-school) { margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--text-90); letter-spacing: -0.003em; }
    :global(.edu-degree) { margin: 0.18rem 0 0; color: var(--text-75); font-size: 0.92rem; }
    :global(.edu-meta) { margin: 0.6rem 0 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
    :global(.edu-pill) {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.18rem 0.6rem;
        border: 1px solid var(--line-divider);
        border-radius: 999px;
        background: var(--btn-plain-bg);
        color: var(--text-50);
        font-size: 0.78rem; font-weight: 600;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    :global(.edu-pill::before) {
        content: "";
        width: 0.72rem;
        height: 0.72rem;
        background-color: currentColor;
        -webkit-mask-position: center;
        mask-position: center;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-size: contain;
        mask-size: contain;
        opacity: 0.8;
    }
    :global(.edu-pill-date::before) {
        -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='4' width='18' height='18' rx='2'/><line x1='16' y1='2' x2='16' y2='6'/><line x1='8' y1='2' x2='8' y2='6'/><line x1='3' y1='10' x2='21' y2='10'/></svg>");
        mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='4' width='18' height='18' rx='2'/><line x1='16' y1='2' x2='16' y2='6'/><line x1='8' y1='2' x2='8' y2='6'/><line x1='3' y1='10' x2='21' y2='10'/></svg>");
    }
    :global(.edu-pill-loc::before) {
        -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z'/><circle cx='12' cy='10' r='3'/></svg>");
        mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z'/><circle cx='12' cy='10' r='3'/></svg>");
    }

    /* ============ 研究兴趣 ============ */
    :global(.interest-tags) { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.25rem; }
    :global(.interest-tag) {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.4rem 0.95rem;
        border: 1px solid color-mix(in oklab, var(--primary) 18%, var(--line-divider));
        border-radius: 999px;
        background: color-mix(in oklab, var(--primary) 4%, var(--btn-plain-bg));
        color: color-mix(in oklab, var(--primary) 88%, var(--text-50));
        font-size: 0.85rem; font-weight: 600;
        transition: all 0.2s ease;
        cursor: default;
    }
    :global(.interest-tag::before) {
        content: "#";
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-weight: 700;
        opacity: 0.55;
    }
    :global(.interest-tag:hover) {
        border-color: var(--primary);
        background: color-mix(in oklab, var(--primary) 13%, var(--btn-plain-bg));
        transform: translateY(-1px);
        box-shadow: 0 6px 16px -8px color-mix(in oklab, var(--primary) 50%, transparent);
    }

    /* ============ 动态 / 论文卡片 ============ */
    :global(.news-list),
    :global(.publication-list) {
        display: grid;
        gap: 0.85rem;
        margin-top: 0.25rem;
    }
    :global(.news-card),
    :global(.publication-card) {
        overflow: hidden;
        border: 1px solid var(--line-divider);
        border-left: 4px solid var(--primary);
        border-radius: var(--radius-large);
        background: color-mix(in oklab, var(--card-bg) 92%, transparent);
        box-shadow: 0 12px 32px rgb(0 0 0 / 4%);
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s, background-color 0.2s;
    }
    :global(.publication-card) { cursor: pointer; }
    :global(.news-card) { padding: 1rem 1.1rem; }
    :global(.publication-card:hover),
    :global(.publication-card[open]),
    :global(.news-card:hover) {
        border-color: color-mix(in oklab, var(--primary) 45%, var(--line-divider));
        box-shadow: 0 16px 38px rgb(0 0 0 / 7%);
        transform: translateY(-1px);
    }
    :global(.publication-summary) {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.75rem;
        padding: 1rem 1.1rem;
        list-style: none;
        user-select: none;
    }
    :global(.publication-summary::-webkit-details-marker) { display: none; }
    :global(.publication-cue) {
        align-self: start;
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.2rem 0.65rem;
        color: var(--primary);
        background: var(--btn-plain-bg);
        font-size: 0.76rem;
        font-weight: 700;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.04em;
        line-height: 1.3;
        white-space: nowrap;
    }
    :global(.publication-card[open] .publication-cue) {
        border-color: var(--primary);
        background: var(--btn-plain-bg-hover);
    }
    :global(.news-title),
    :global(.publication-title) {
        margin: 0;
        color: var(--text-90);
        font-size: 1.02rem;
        font-weight: 700;
        line-height: 1.5;
    }
    :global(.news-meta) {
        margin: 0.3rem 0 0;
        color: var(--primary);
        font-size: 0.78rem;
        font-weight: 700;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.05em;
    }
    :global(.news-description) {
        margin: 0.45rem 0 0;
        color: var(--text-75);
        line-height: 1.7;
        font-size: 0.92rem;
    }
    :global(.publication-authors) {
        margin: 0.35rem 0 0;
        color: var(--text-75);
        line-height: 1.65;
        font-size: 0.88rem;
    }
    :global(.publication-venue) {
        margin: 0.2rem 0 0;
        color: var(--text-50);
        font-style: italic;
        font-size: 0.85rem;
    }
    :global(.publication-body) {
        border-top: 1px solid var(--line-divider);
        padding: 0.9rem 1.1rem 1.05rem;
        color: var(--text-75);
        cursor: default;
    }
    :global(.publication-body h4) {
        margin: 0 0 0.25rem;
        color: var(--text-90);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    :global(.publication-body p) {
        margin: 0 0 0.6rem;
        font-size: 0.92rem;
    }
    :global(.publication-links) {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0;
    }
    /* 按钮基础样式 */
    :global(.publication-links a),
    :global(.publication-resource),
    :global(.publication-link-disabled) {
        border-radius: 999px;
        border: 1px solid var(--line-divider);
        padding: 0.25rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none !important;
    }

    /* BibTeX 切换按钮 */
    :global(.publication-resource) {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--primary);
        background: var(--btn-plain-bg);
        cursor: pointer;
        list-style: none;
        transition: background-color 0.2s, border-color 0.2s, color 0.2s;
    }
    :global(.publication-resource::before) {
        content: "{ }";
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.78rem;
        font-weight: 700;
        opacity: 0.65;
    }
    :global(.publication-resource:hover),
    :global(.publication-bibtex-details[open] .publication-resource) {
        border-color: color-mix(in oklab, var(--primary) 38%, var(--line-divider));
        background: color-mix(in oklab, var(--primary) 7%, var(--btn-plain-bg));
    }
    :global(.publication-resource::-webkit-details-marker) { display: none; }

    /* 禁用链接（真正不可用） */
    :global(.publication-link-disabled:not([href])) {
        color: var(--text-30);
        cursor: not-allowed;
    }

    /* 外链美化：带 href 的链接显示为主色 + 外链箭头 */

    :global(a.publication-link-disabled[href]) {
        color: var(--primary);
        border-color: color-mix(in oklab, var(--primary) 38%, var(--line-divider));
        background: transparent;
        cursor: pointer;
        display: inline-flex;
        flex-direction: row;         /* 强制水平排列 */
        align-items: center;
        flex-wrap: nowrap;           /* 防止换行 */
        gap: 0.3rem;
        white-space: nowrap;         /* 文字和箭头始终在同一行 */
        text-decoration: none;
        transition: background-color 0.2s, border-color 0.2s;
    }

    :global(a.publication-link-disabled[href]:hover) {
        background: color-mix(in oklab, var(--primary) 7%, var(--btn-plain-bg));
        border-color: var(--primary);
    }

    /* 箭头图标，作为 flex 子元素放在文字前面 */
    :global(a.publication-link-disabled[href]::before) {
        content: "";
        display: inline-block;       /* 改为 inline-block 保持行内 */
        width: 0.7rem;
        height: 0.7rem;
        flex-shrink: 0;              /* 防止被挤压 */
        margin-right: 0.25rem;
        background-color: currentColor;
        mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'/><polyline points='15 3 21 3 21 9'/><line x1='10' y1='14' x2='21' y2='3'/></svg>");
        -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'/><polyline points='15 3 21 3 21 9'/><line x1='10' y1='14' x2='21' y2='3'/></svg>");
        opacity: 0.8;
    }

    @media (max-width: 640px) {
        :global(.publication-summary) { grid-template-columns: 1fr; }
        :global(.publication-cue) { justify-self: start; }
    }

    :global(.publication-bibtex-details) { display: contents; }

    /* ============ BibTeX 代码块 ——— 显式纯白/纯黑 + 明显边框 ============ */
    :global(.publication-bibtex) {
        position: relative;
        overflow: hidden;
        margin: 0.75rem 0 0 !important;
        padding: 0 !important;
        border: 1px solid rgb(0 0 0 / 16%) !important;
        border-radius: 10px;
        background: #ffffff !important;
        box-shadow: none !important;
    }
    :global(.publication-bibtex::before),
    :global(.publication-bibtex::after) {
        content: none !important;
    }
    :global(.publication-bibtex code) {
        display: block;
        padding: 1rem 1.1rem !important;
        background: transparent !important;
        color: #18181b !important;
        font-family:
            "JetBrains Mono Variable",
            ui-monospace,
            SFMono-Regular,
            Menlo,
            Monaco,
            Consolas,
            monospace;
        font-size: 0.82rem;
        line-height: 1.7;
        white-space: pre;
        overflow-x: auto;
        tab-size: 2;
        scrollbar-width: thin;
        scrollbar-color: rgb(0 0 0 / 25%) transparent;
    }
    :global(.publication-bibtex code::before),
    :global(.publication-bibtex code::after) { content: none !important; }
    :global(.publication-bibtex code::-webkit-scrollbar) { height: 6px; }
    :global(.publication-bibtex code::-webkit-scrollbar-thumb) {
        background: rgb(0 0 0 / 25%);
        border-radius: 999px;
    }

    /* 暗色模式 —— 覆盖站点的 .dark 类（Fuwari 用 html.dark） */
    :global(html.dark) :global(.publication-bibtex),
    :global(.dark) :global(.publication-bibtex) {
        background: #0d0e11 !important;
        border-color: rgb(255 255 255 / 16%) !important;
    }
    :global(html.dark) :global(.publication-bibtex code),
    :global(.dark) :global(.publication-bibtex code) {
        color: #f4f4f5 !important;
        scrollbar-color: rgb(255 255 255 / 25%) transparent;
    }
    :global(html.dark) :global(.publication-bibtex code::-webkit-scrollbar-thumb),
    :global(.dark) :global(.publication-bibtex code::-webkit-scrollbar-thumb) {
        background: rgb(255 255 255 / 25%);
    }

    /* Copy 按钮 */
    :global(.publication-bibtex-copy) {
        position: absolute;
        top: 0.45rem;
        right: 0.45rem;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        height: 1.55rem;
        padding: 0 0.55rem;
        border: 1px solid transparent;
        border-radius: 7px;
        background: transparent;
