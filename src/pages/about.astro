        opacity: 1;
    }
    :global(.publication-bibtex-copy svg) {
        width: 0.78rem;
        height: 0.78rem;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    /* ============ 奖项 ============ */
    :global(.award-section) { margin-top: 1.5rem; }
    :global(.about-content .award-section:first-of-type) { margin-top: 0.25rem; }
    :global(.award-group-title) {
        display: flex !important;
        align-items: center;
        gap: 0.6rem;
        margin: 0 0 0.85rem !important;
        padding: 0 !important;
        border: none !important;
        font-size: 1rem !important;
        font-weight: 700 !important;
        color: var(--text-90) !important;
    }
    :global(.award-group-title::before) {
        content: "";
        width: 0.32rem;
        height: 1rem;
        background: var(--primary);
        border-radius: 2px;
    }
    :global(.award-group-title::after) { content: none !important; }
    :global(.award-list) {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 0.6rem;
        margin: 0 !important;
        padding: 0 !important;
        list-style: none !important;
    }
    :global(.award-list li) { list-style: none !important; }
    :global(.award-item) {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.85rem;
        align-items: center;
        padding: 0.8rem 0.95rem;
        border: 1px solid var(--line-divider);
        border-left: 3px solid var(--primary);
        border-radius: var(--radius-large);
        background: color-mix(in oklab, var(--card-bg) 94%, transparent);
        transition: all 0.18s ease;
    }
    :global(.award-item:hover) {
        border-color: color-mix(in oklab, var(--primary) 35%, var(--line-divider));
        background: color-mix(in oklab, var(--primary) 4%, var(--card-bg));
        transform: translateX(2px);
