        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        opacity: 0.7;
        transition: all 0.18s;
    }
    :global(html.dark) :global(.publication-bibtex-copy),
    :global(.dark) :global(.publication-bibtex-copy) {
        color: rgb(255 255 255 / 60%);
    }
    :global(.publication-bibtex:hover .publication-bibtex-copy) { opacity: 1; }
    :global(.publication-bibtex-copy:hover) {
        border-color: rgb(0 0 0 / 12%);
        background: rgb(0 0 0 / 4%);
        color: var(--primary);
    }
    :global(html.dark) :global(.publication-bibtex-copy:hover),
    :global(.dark) :global(.publication-bibtex-copy:hover) {
