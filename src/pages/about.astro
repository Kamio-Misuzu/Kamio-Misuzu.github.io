    :global(.award-item.award-gold) { border-left-color: #e0a823; }
    :global(.award-item.award-silver) { border-left-color: #98a0ab; }
    :global(.award-item.award-bronze) { border-left-color: #c97a3d; }
    :global(.award-medal) {
        width: 1.85rem;
        height: 1.85rem;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.72rem;
        font-weight: 800;
        color: var(--primary);
        background: color-mix(in oklab, var(--primary) 12%, var(--btn-plain-bg));
        border: 1px solid color-mix(in oklab, var(--primary) 25%, var(--line-divider));
        flex-shrink: 0;
        letter-spacing: -0.02em;
    }
    :global(.award-gold .award-medal) {
        color: #b08000;
        background: color-mix(in oklab, #e0a823 18%, var(--btn-plain-bg));
        border-color: color-mix(in oklab, #e0a823 35%, var(--line-divider));
    }
    :global(.award-silver .award-medal) {
        color: #5a6470;
        background: color-mix(in oklab, #98a0ab 18%, var(--btn-plain-bg));
        border-color: color-mix(in oklab, #98a0ab 35%, var(--line-divider));
    }
    :global(.award-bronze .award-medal) {
        color: #8e5223;
        background: color-mix(in oklab, #c97a3d 18%, var(--btn-plain-bg));
        border-color: color-mix(in oklab, #c97a3d 35%, var(--line-divider));
    }
    :global(.award-text) { min-width: 0; }
    :global(.award-name) {
        margin: 0 !important;
        color: var(--text-90);
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.4;
    }
    :global(.award-detail) {
        margin: 0.18rem 0 0 !important;
        color: var(--text-50);
        font-size: 0.78rem;
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.01em;
    }

    /* 可点击查看证书 */
    :global(.award-item.has-cert) {
        position: relative;
        padding-right: 2.5rem;
        cursor: pointer;
    }
    :global(.award-item.has-cert::after) {
        content: "";
        position: absolute;
        top: 50%;
        right: 0.9rem;
        width: 1.05rem;
        height: 1.05rem;
        transform: translateY(-50%);
        background-color: var(--text-50);
        opacity: 0.45;
        -webkit-mask-position: center;
        mask-position: center;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z'/><circle cx='12' cy='12' r='3'/></svg>");
        mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z'/><circle cx='12' cy='12' r='3'/></svg>");
        transition: opacity 0.2s, background-color 0.2s, right 0.2s;
    }
    :global(.award-item.has-cert:hover::after),
    :global(.award-item.has-cert:focus-visible::after) {
        opacity: 0.95;
        background-color: var(--primary);
        right: 0.75rem;
    }
    :global(.award-item.has-cert:focus-visible) {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
    }

    /* ============ 证书弹窗 ——— 缩小 + flex 永不溢出 ============ */
    :global(.cert-modal) {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: grid;
        place-items: center;
        padding: 2.5rem 1.5rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.22s ease;
    }
    :global(.cert-modal[data-state="open"]) {
        opacity: 1;
        pointer-events: auto;
    }
    :global(.cert-modal-backdrop) {
        position: absolute;
        inset: 0;
        background: rgb(8 10 14 / 75%);
        -webkit-backdrop-filter: blur(8px) saturate(140%);
        backdrop-filter: blur(8px) saturate(140%);
    }
    :global(.cert-modal-stage) {
        position: relative;
        z-index: 1;
        /* 比之前更小 */
        width: min(82vw, 880px);
        max-height: calc(100vh - 5rem);
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        transform: scale(0.96) translateY(8px);
        opacity: 0;
        transition: transform 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.22s;
    }
    :global(.cert-modal[data-state="open"] .cert-modal-stage) {
        transform: scale(1) translateY(0);
        opacity: 1;
    }
    :global(.cert-modal-close) {
        position: absolute;
        top: 0.55rem;
        right: 0.55rem;
        z-index: 3;
        width: 2.1rem;
        height: 2.1rem;
        border-radius: 999px;
        border: 1px solid rgb(255 255 255 / 25%);
        background: rgb(20 20 24 / 55%);
        -webkit-backdrop-filter: blur(6px);
        backdrop-filter: blur(6px);
        color: rgb(255 255 255 / 95%);
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: all 0.18s;
    }
    :global(.cert-modal-close:hover) {
        background: rgb(20 20 24 / 80%);
        border-color: rgb(255 255 255 / 45%);
    }
    :global(.cert-modal-close:active) { transform: scale(0.95); }
    :global(.cert-modal-close svg) {
        width: 1rem;
        height: 1rem;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
        stroke-linecap: round;
    }
    :global(.cert-modal-image-wrap) {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-large);
        overflow: hidden;
        background: rgb(255 255 255 / 5%);
        box-shadow: 0 30px 80px rgb(0 0 0 / 50%), 0 0 0 1px rgb(255 255 255 / 8%);
    }
    :global(.cert-modal-image) {
        display: block;
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        opacity: 0;
        transition: opacity 0.25s ease;
    }
    :global(.cert-modal-image.is-loaded) { opacity: 1; }
    :global(.cert-modal-spinner) {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 2.25rem;
        height: 2.25rem;
        margin: -1.125rem 0 0 -1.125rem;
        border-radius: 50%;
        border: 2px solid rgb(255 255 255 / 18%);
        border-top-color: rgb(255 255 255 / 78%);
        animation: cert-spin 0.9s linear infinite;
        transition: opacity 0.2s ease;
    }
    :global(.cert-modal-spinner.is-hidden) { opacity: 0; }
    @keyframes cert-spin { to { transform: rotate(360deg); } }
    :global(.cert-modal-caption) {
        flex: 0 0 auto;
        align-self: center;
        margin: 0;
        padding: 0.45rem 0.95rem;
        max-width: 100%;
        border-radius: 999px;
        background: rgb(255 255 255 / 10%);
        color: rgb(255 255 255 / 94%);
        font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.76rem;
        letter-spacing: 0.04em;
        text-align: center;
        line-height: 1.5;
        word-break: break-word;
    }

    @media (max-width: 640px) {
        :global(.cert-modal) { padding: 1rem; }
        :global(.cert-modal-stage) {
            width: 100%;
            max-height: calc(100vh - 2rem);
        }
    }
</style>

<script>
    const STORAGE_KEY = "about-lang";

    function initLangSwitch() {
        const buttons = Array.from(document.querySelectorAll("[data-about-lang-button]"));
        const panels = Array.from(document.querySelectorAll("[data-about-lang-panel]"));
        if (buttons.length === 0 || panels.length === 0) return;

        const setLang = (lang) => {
            buttons.forEach((b) => {
                const active = b.dataset.aboutLangButton === lang;
                b.classList.toggle("active", active);
                b.setAttribute("aria-pressed", String(active));
            });
            panels.forEach((p) => {
                p.hidden = p.dataset.aboutLangPanel !== lang;
            });
            try { localStorage.setItem(STORAGE_KEY, lang); } catch (e) {}
            requestAnimationFrame(() => rebuildToc(lang));
        };

        let initial = "en";
        try {
            initial = localStorage.getItem(STORAGE_KEY)
                ?? (navigator.language.startsWith("zh") ? "zh" : "en");
        } catch (e) {
            initial = navigator.language.startsWith("zh") ? "zh" : "en";
        }
        setLang(initial);

        buttons.forEach((b) => {
            if (b.dataset.langBound === "true") return;
            b.dataset.langBound = "true";
            b.addEventListener("click", () => setLang(b.dataset.aboutLangButton ?? "en"));
        });
    }

    // ---------- BibTeX 复制按钮 ----------
    const COPY_ICON = `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V6a2 2 0 0 1 2-2h9"></path></svg>`;
    const CHECK_ICON = `<svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

    function enhanceBibtex() {
        document.querySelectorAll("pre.publication-bibtex").forEach((pre) => {
            if (pre.dataset.copyEnhanced === "true") return;
            pre.dataset.copyEnhanced = "true";

            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "publication-bibtex-copy";
            btn.setAttribute("aria-label", "Copy BibTeX");
            btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;
            pre.appendChild(btn);

            btn.addEventListener("click", async (event) => {
                event.preventDefault();
                event.stopPropagation();
                const codeEl = pre.querySelector("code");
                const text = (codeEl ? codeEl.innerText : pre.innerText).trim();
                try {
                    await navigator.clipboard.writeText(text);
                } catch (e) {
                    const ta = document.createElement("textarea");
                    ta.value = text;
                    ta.style.position = "fixed";
                    ta.style.opacity = "0";
                    document.body.appendChild(ta);
                    ta.select();
                    try { document.execCommand("copy"); } catch (_) {}
                    document.body.removeChild(ta);
                }
                btn.classList.add("is-copied");
                btn.innerHTML = `${CHECK_ICON}<span>Copied</span>`;
                setTimeout(() => {
                    btn.classList.remove("is-copied");
                    btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;
                }, 1600);
            });
        });
    }

    // ---------- 证书弹窗 ----------
    function resolveCertUrl(key) {
        if (!key) return "";
        const map = window.__certImageMap || {};
        if (map[key]) return map[key];
        const base = key.split("/").pop();
        if (base && map[base]) return map[base];
        return key;
    }

    function initCertModal() {
        const modal = document.querySelector("[data-cert-modal]");
        if (!modal) return;
        if (modal.dataset.bound === "true") return;
        modal.dataset.bound = "true";

        const img = modal.querySelector("[data-cert-modal-img]");
        const titleEl = modal.querySelector("[data-cert-modal-title]");
        const backdrop = modal.querySelector("[data-cert-modal-backdrop]");
        const closeBtn = modal.querySelector("[data-cert-modal-close]");
        const spinner = modal.querySelector("[data-cert-modal-spinner]");
        if (!img || !titleEl || !spinner) return;

        let lastFocus = null;

        const open = (rawKey, title, source) => {
            const url = resolveCertUrl(rawKey);
            lastFocus = source;
            titleEl.textContent = title || "";
            img.classList.remove("is-loaded");
            spinner.classList.remove("is-hidden");
            img.src = url;
            img.alt = title || "";
            modal.hidden = false;
            void modal.offsetWidth;
            modal.dataset.state = "open";
            document.body.style.overflow = "hidden";
            setTimeout(() => closeBtn && closeBtn.focus(), 50);
        };

        const close = () => {
            delete modal.dataset.state;
            document.body.style.overflow = "";
            setTimeout(() => {
                modal.hidden = true;
                img.src = "";
                if (lastFocus) {
                    try { lastFocus.focus(); } catch (e) {}
                    lastFocus = null;
                }
            }, 220);
        };

        img.addEventListener("load", () => {
            img.classList.add("is-loaded");
            spinner.classList.add("is-hidden");
        });
        img.addEventListener("error", () => {
            spinner.classList.add("is-hidden");
            titleEl.textContent = "图片加载失败 / Image failed to load: " + img.src;
        });

        document.addEventListener("click", (event) => {
            const t = event.target;
            if (!t) return;
            const item = t.closest && t.closest(".award-item.has-cert");
            if (item && !(t.closest && t.closest("[data-cert-modal]"))) {
                event.preventDefault();
                const key = item.dataset.cert || "";
                const title = item.dataset.certTitle || "";
                if (key) open(key, title, item);
                return;
            }
            if (
                (t.closest && t.closest("[data-cert-modal-close]")) ||
                t === backdrop
            ) {
                close();
            }
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && !modal.hidden) {
                close();
                return;
            }
            if (event.key === "Enter" || event.key === " ") {
                const active = document.activeElement;
                if (active && active.classList && active.classList.contains("has-cert")) {
                    event.preventDefault();
                    const key = active.dataset.cert || "";
                    const title = active.dataset.certTitle || "";
                    if (key) open(key, title, active);
                }
            }
        });
    }

    function makeAwardsFocusable() {
        document.querySelectorAll(".award-item.has-cert").forEach((el) => {
            if (!el.hasAttribute("tabindex")) el.setAttribute("tabindex", "0");
            if (!el.hasAttribute("role")) el.setAttribute("role", "button");
        });
    }

    // ---------- 右侧目录（悬浮固定定位）----------
    let tocObserver = null;

    function positionToc() {
        const toc = document.querySelector("[data-about-toc]");
        if (!toc) return;
        const card = document.querySelector(".card-base");
        if (!card) return;

        const minWidth = 1280; // 小于此宽度隐藏目录
        if (window.innerWidth < minWidth) {
            toc.hidden = true;
            return;
        }

        const cardRect = card.getBoundingClientRect();
        const rightOffset = Math.min(24, (window.innerWidth - cardRect.right) / 2);
        const left = cardRect.right + rightOffset + 16; // 16px 间距

        toc.style.left = `${left}px`;
        toc.style.top = "5rem";    // 保持与顶部导航的距离
        toc.hidden = false;
    }

    function rebuildToc(currentLang) {
        const toc = document.querySelector("[data-about-toc]");
        if (!toc) return;
        const list = toc.querySelector("[data-about-toc-list]");
        const titleEl = toc.querySelector("[data-about-toc-title]");
        if (!list) return;

        const activePanel = currentLang
            ? document.querySelector(`[data-about-lang-panel="${currentLang}"]`)
            : document.querySelector("[data-about-lang-panel]:not([hidden])");
        if (!activePanel) {
            toc.hidden = true;
            return;
        }

        const h2s = Array.from(activePanel.querySelectorAll("h2"));
        if (h2s.length === 0) {
            toc.hidden = true;
            return;
        }

        // 标题本地化
        if (titleEl) {
            titleEl.textContent = currentLang === "zh" ? "本页目录" : "On this page";
        }
        list.innerHTML = "";

        h2s.forEach((h2, idx) => {
            if (!h2.id) {
                const lang = activePanel.dataset.aboutLangPanel || "en";
                h2.id = `about-${lang}-${idx}`;
            }
            const li = document.createElement("li");
            const a = document.createElement("a");
            a.href = "#" + h2.id;
            a.textContent = (h2.textContent || "").trim();
            a.className = "about-toc-link";
            a.dataset.tocTarget = h2.id;
            a.addEventListener("click", (e) => {
                e.preventDefault();
                const target = document.getElementById(h2.id);
                if (target) {
                    target.scrollIntoView({ behavior: "smooth", block: "start" });
                    try { history.replaceState(null, "", "#" + h2.id); } catch (_) {}
                }
            });
            li.appendChild(a);
            list.appendChild(li);
        });

        setupTocObserver(h2s);
        positionToc(); // 重建后重新定位
    }

    function setupTocObserver(headings) {
        if (tocObserver) tocObserver.disconnect();

        const links = Array.from(document.querySelectorAll(".about-toc-link"));
        const visible = new Set();

        tocObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) visible.add(entry.target.id);
                else visible.delete(entry.target.id);
            });

            const ordered = headings.filter((h) => visible.has(h.id));
            let activeId;
            if (ordered.length) {
                activeId = ordered[0].id;
            } else {
                let last = null;
                for (const h of headings) {
                    if (h.getBoundingClientRect().top < window.innerHeight * 0.3) last = h;
                }
                activeId = last ? last.id : (headings[0] && headings[0].id);
            }

            links.forEach((link) => {
                link.classList.toggle("is-active", link.dataset.tocTarget === activeId);
            });
        }, {
            rootMargin: "-15% 0px -70% 0px",
            threshold: 0,
        });

        headings.forEach((h) => tocObserver.observe(h));
    }

    // 窗口 resize 和滚动时重新定位目录
    let positionTocThrottle = null;
    function onPositionUpdate() {
        if (positionTocThrottle) return;
        positionTocThrottle = requestAnimationFrame(() => {
            positionToc();
            positionTocThrottle = null;
        });
    }

    window.addEventListener("resize", onPositionUpdate);
    window.addEventListener("scroll", onPositionUpdate, { passive: true });

    function bootstrap() {
        initLangSwitch();
        enhanceBibtex();
        initCertModal();
        makeAwardsFocusable();
        rebuildToc();
    }

    bootstrap();
    document.addEventListener("astro:page-load", bootstrap);
    document.addEventListener("astro:after-swap", bootstrap);
</script>